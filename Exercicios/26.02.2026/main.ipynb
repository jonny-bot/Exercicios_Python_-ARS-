   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "idade = [25,30,35,40,45,50]\n",
    "salario = [3000,3500,40000,4500,5000,5500]\n",
    "\n",
    "plt.scatter(idade, salario)\n",
    "\n",
    "plt.title(\"Relação entre Idade-Salário\")\n",
    "plt.xlabel(\"Idade\")\n",
    "plt.ylabel(\"Salário\")\n",
    "plt.grid(True)\n",
    "plt.show()"
   ],
